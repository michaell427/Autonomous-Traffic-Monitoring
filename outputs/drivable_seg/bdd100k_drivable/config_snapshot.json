{
  "paths": {
    "root_dir": ".",
    "images_dir": "bdd100k_images_100k/100k",
    "drivable_masks_dir": "bdd100k_drivable_maps/color_labels"
  },
  "data": {
    "train_split": "train",
    "val_split": "val",
    "image_size": [
      640,
      640
    ],
    "batch_size": 16,
    "num_workers": 4,
    "max_train_samples": null,
    "max_val_samples": null,
    "val_holdout_from_train_fraction": 0.05,
    "val_holdout_seed": 42
  },
  "model": {
    "backbone": "deeplabv3_resnet50",
    "pretrained": true
  },
  "training": {
    "epochs": 10,
    "lr": 0.0001,
    "weight_decay": 0.0001,
    "aux_loss_weight": 0.4,
    "amp": true,
    "log_interval": 50
  },
  "classes": {
    "num_classes": 3,
    "names": [
      "direct",
      "alternative",
      "background"
    ],
    "ignore_index": 255
  }
}